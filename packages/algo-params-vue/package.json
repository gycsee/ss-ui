{
  "name": "@cardinal-odp/algo-params-vue",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm exec unbuild",
    "test": "pnpm build && node --test ./__tests__/*.test.mjs"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
