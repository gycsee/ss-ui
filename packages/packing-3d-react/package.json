{
  "name": "@cardinal-odp/packing-3d-react",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "pnpm exec tsup --config tsup.config.ts",
    "test": "pnpm build && node --test ./__tests__/*.test.mjs"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    }
  },
  "peerDependencies": {
    "@react-three/drei": ">=9.0.0",
    "@react-three/fiber": ">=8.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "three": ">=0.160.0"
  },
  "peerDependenciesMeta": {
    "@react-three/drei": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/three": "^0.184.0",
    "tsup": "^8.3.5"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      }
    }
  }
}
